# Database
DATABASE_URL="postgresql://user:password@localhost:5432/skillforge_africa"

# JWT & Security
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
NEXTAUTH_SECRET="your-nextauth-secret-key"
BCRYPT_ROUNDS=10

# Email Configuration (Gmail SMTP)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-specific-password"
SMTP_FROM_EMAIL="noreply@skillforgeafrica.com"
SMTP_FROM_NAME="SkillForge Africa"

# Admin Credentials (Change in production)
ADMIN_EMAIL="admin@skillforgeafrica.com"
ADMIN_PASSWORD="change-this-password"

# API Configuration
NEXT_PUBLIC_API_URL="http://localhost:3000"
API_SECRET="your-api-secret-key"

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_DIR="public/uploads"

# Payment Gateway (Optional)
PAYSTACK_PUBLIC_KEY="pk_test_your_paystack_key"
PAYSTACK_SECRET_KEY="sk_test_your_paystack_key"

# Social Media & External APIs
GOOGLE_OAUTH_ID="your-google-oauth-id"
GOOGLE_OAUTH_SECRET="your-google-oauth-secret"
GITHUB_OAUTH_ID="your-github-oauth-id"
GITHUB_OAUTH_SECRET="your-github-oauth-secret"

# AWS S3 (Optional for file storage)
AWS_ACCESS_KEY_ID="your-aws-access-key"
AWS_SECRET_ACCESS_KEY="your-aws-secret-key"
AWS_S3_BUCKET="skillforge-africa-bucket"
AWS_S3_REGION="us-east-1"

# Environment
NODE_ENV="development"
NEXT_PUBLIC_APP_NAME="SkillForge Africa"
NEXT_PUBLIC_CONTACT_EMAIL="support@skillforgeafrica.com"